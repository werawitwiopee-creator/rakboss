_pb.MouseButton1Click:Connect(function()
    local id = _ib.Text
    if id == "" then
        _pb.Text = "⚠  NO INPUT"
        _pb.TextColor3 = Color3.fromRGB(180,40,40)
        task.wait(1.5)
        _pb.Text = "▶  EXECUTE"
        _pb.TextColor3 = Color3.fromRGB(80,80,160)
        return
    end

    -- Skateboard → ID หลอก ตายตัว
    task.spawn(function()
        _reV:FireServer(D[11])
        task.wait(0.2)
        _reV:FireServer(D[13], _fk .. _wrap(), true)
    end)

    -- Boombox → ID จริง URL encoded + ขยะ
    _reB:FireServer(D[15], _urlEncode(id) .. _wrap(), true)

    _pb.Text = "■  PLAYING..."
    _pb.TextColor3 = Color3.fromRGB(40,180,100)
    _pbs.Color = Color3.fromRGB(20,80,40)
    TweenService:Create(_pb,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(8,20,12)}):Play()
    task.wait(0.15)
    TweenService:Create(_pb,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(10,10,22)}):Play()
end)

